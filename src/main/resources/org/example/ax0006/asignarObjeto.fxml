<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="800.0" prefWidth="1200.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.ax0006.Controller.asignarObjetoController">

    <children>

        <Text layoutX="380.0" layoutY="100.0" text="Asignar Objeto a Inventario">
            <font><Font size="24.0"/></font>
        </Text>

        <Label layoutX="350.0" layoutY="250.0" text="ID Inventario:"/>
        <TextField fx:id="ii_inventario" layoutX="520.0" layoutY="240.0"/>

        <Label layoutX="350.0" layoutY="320.0" text="ID Objeto:"/>
        <TextField fx:id="ii_objeto" layoutX="520.0" layoutY="310.0"/>

        <Button fx:id="bt_asignar" layoutX="520.0" layoutY="380.0"
                text="Asignar" onAction="#on_bt_asignar"/>

        <Label fx:id="lbl_msg" layoutX="520.0" layoutY="440.0"/>

    </children>
</Pane>