<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="800.0" prefWidth="1200.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <Text layoutX="450.0" layoutY="100.0" text="Crear Inventario">
            <font><Font size="26.0"/></font>
        </Text>

        <Button fx:id="bt_crear" layoutX="500.0" layoutY="300.0"
                text="Crear Inventario" onAction="#on_bt_crear"/>

        <Label fx:id="lbl_msg" layoutX="500.0" layoutY="360.0"/>

        <DatePicker fx:id="dp_fechaInicio" layoutX="450.0" layoutY="200.0"/>
        <DatePicker fx:id="dp_fechaFin" layoutX="650.0" layoutY="200.0"/>

        <TextField fx:id="tf_horaInicio" layoutX="450.0" layoutY="250.0" promptText="HH:mm"/>
        <TextField fx:id="tf_horaFin" layoutX="650.0" layoutY="250.0" promptText="HH:mm"/>

        <Button fx:id="bt_volver"
                layoutX="1100.0" layoutY="740.0"
                text="Volver"
                onAction="#on_bt_volver"/>
    </children>
</Pane>