<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to bottom right, #eef2f7, #dfe7f1);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <!-- Panel lateral decorativo -->
        <AnchorPane prefHeight="800.0" prefWidth="520.0" style="-fx-background-color: linear-gradient(to bottom right, #1e3c72, #2a5298);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox layoutX="70.0" layoutY="160.0" spacing="18.0">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;" text="Crea tu cuenta" />
                        <Label prefWidth="360.0" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 17px;" text="Regístrate para comenzar a usar la plataforma de forma rápida y segura." wrapText="true" />
                        <Label style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 14px;" text="Seguro • Moderno • Profesional" />
                    </children>
                </VBox>
            </children>
        </AnchorPane>

        <!-- Tarjeta principal -->
        <VBox layoutX="640.0" layoutY="95.0" prefWidth="390.0" spacing="14.0" style="-fx-background-color: white;                    -fx-background-radius: 20;                    -fx-border-radius: 20;                    -fx-padding: 32;                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 24, 0.2, 0, 8);">

            <children>
                <Label style="-fx-text-fill: #1f2937; -fx-font-size: 28px; -fx-font-weight: bold;" text="Crear Usuario" />

                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 13px;" text="Completa los datos para registrarte" />

                <Separator />

                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: bold;" text="Correo" />
                        <TextField fx:id="fid_correo" promptText="correo@ejemplo.com" style="-fx-background-color: #f9fafb;                                     -fx-background-radius: 12;                                     -fx-border-color: #d1d5db;                                     -fx-border-radius: 12;                                     -fx-padding: 10 12 10 12;                                     -fx-font-size: 14px;" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: bold;" text="Usuario" />
                        <TextField fx:id="fid_Usuario" promptText="Nombre de usuario" style="-fx-background-color: #f9fafb;                                     -fx-background-radius: 12;                                     -fx-border-color: #d1d5db;                                     -fx-border-radius: 12;                                     -fx-padding: 10 12 10 12;                                     -fx-font-size: 14px;" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: bold;" text="Contraseña" />
                        <HBox spacing="8.0">
                            <children>
                                <StackPane prefWidth="290.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <PasswordField fx:id="fid_Contrasena" promptText="Escribe tu contraseña" style="-fx-background-color: #f9fafb;                                                     -fx-background-radius: 12;                                                     -fx-border-color: #d1d5db;                                                     -fx-border-radius: 12;                                                     -fx-padding: 10 12 10 12;                                                     -fx-font-size: 14px;" />
                                        <TextField fx:id="fid_ContrasenaVisible" managed="false" promptText="Escribe tu contraseña" style="-fx-background-color: #f9fafb;                                                 -fx-background-radius: 12;                                                 -fx-border-color: #d1d5db;                                                 -fx-border-radius: 12;                                                 -fx-padding: 10 12 10 12;                                                 -fx-font-size: 14px;" visible="false" />
                                    </children>
                                </StackPane>
                                <Button ellipsisString="👁" onAction="#togglePassword" style="-fx-background-color: #e5e7eb;                                        -fx-background-radius: 12;                                        -fx-text-fill: #374151;                                        -fx-font-size: 14px;                                        -fx-cursor: hand;                                        -fx-padding: 10 14 10 14;" text="👁" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-text-fill: #111827; -fx-font-size: 14px; -fx-font-weight: bold;" text="Confirmar Contraseña" />
                        <HBox spacing="8.0">
                            <children>
                                <StackPane prefWidth="290.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <PasswordField fx:id="fid_ContrasenaConfirmation" promptText="Repite tu contraseña" style="-fx-background-color: #f9fafb;                                                     -fx-background-radius: 12;                                                     -fx-border-color: #d1d5db;                                                     -fx-border-radius: 12;                                                     -fx-padding: 10 12 10 12;                                                     -fx-font-size: 14px;" />
                                        <TextField fx:id="fid_ContrasenaVisibleConfirmation" managed="false" promptText="Repite tu contraseña" style="-fx-background-color: #f9fafb;                                                 -fx-background-radius: 12;                                                 -fx-border-color: #d1d5db;                                                 -fx-border-radius: 12;                                                 -fx-padding: 10 12 10 12;                                                 -fx-font-size: 14px;" visible="false" />
                                    </children>
                                </StackPane>
                                <Button onAction="#togglePasswordConfirmation" style="-fx-background-color: #e5e7eb;                                        -fx-background-radius: 12;                                        -fx-text-fill: #374151;                                        -fx-font-size: 14px;                                        -fx-cursor: hand;                                        -fx-padding: 10 14 10 14;" text="👁" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="10.0" style="-fx-padding: 12 0 0 0;">
                    <children>
                        <Button fx:id="fid_sign_up" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#On_crear_usuario" style="-fx-background-color: linear-gradient(to right, #10b981, #059669);                                  -fx-background-radius: 12;                                  -fx-text-fill: white;                                  -fx-font-size: 14px;                                  -fx-font-weight: bold;                                  -fx-cursor: hand;                                  -fx-padding: 12 18 12 18;" text="Crear Usuario" />

                        <Button fx:id="fid_login" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#On_login" style="-fx-background-color: #f3f4f6;                                  -fx-background-radius: 12;                                  -fx-text-fill: #374151;                                  -fx-font-size: 14px;                                  -fx-font-weight: bold;                                  -fx-cursor: hand;                                  -fx-padding: 12 18 12 18;                                  -fx-border-color: #d1d5db;                                  -fx-border-radius: 12;" text="Login" />
                    </children>
                </VBox>
            </children>
        </VBox>

    </children>
</AnchorPane>
