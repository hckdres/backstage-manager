<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0"
            xmlns:fx="http://javafx.com/fxml">

    <children>

        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <!-- =========================
                 TOP: TITULO
            ========================= -->
            <top>
                <Label text="Gestión Financiera del Evento"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;"
                       BorderPane.alignment="CENTER">
                    <BorderPane.margin>
                        <Insets top="20" bottom="20"/>
                    </BorderPane.margin>
                </Label>
            </top>

            <!-- =========================
                 CENTER: CONTENIDO
            ========================= -->
            <center>
                <VBox spacing="20" alignment="CENTER">

                    <padding>
                        <Insets top="30" left="30" right="30" bottom="30"/>
                    </padding>

                    <!-- ID -->
                    <HBox spacing="15" alignment="CENTER">
                        <Label text="ID Presupuesto:"/>
                        <TextField fx:id="fid_id" prefWidth="200"/>
                    </HBox>

                    <!-- PRESUPUESTO -->
                    <HBox spacing="15" alignment="CENTER">
                        <Label text="Presupuesto:"/>
                        <TextField fx:id="fid_presupuesto" prefWidth="200"/>
                        <Button text="Crear" onAction="#On_crearPresupuesto"/>
                        <Button text="Eliminar" onAction="#On_eliminarPresupuesto"/>
                    </HBox>

                    <!-- GASTOS -->
                    <HBox spacing="15" alignment="CENTER">
                        <Label text="Gasto:"/>
                        <TextField fx:id="fid_gasto" prefWidth="200"/>
                        <Button text="Agregar Gasto" onAction="#On_registrarGasto"/>
                        <Button text="Eliminar Gasto" onAction="#On_eliminarGasto"/>
                    </HBox>

                    <!-- PRECIO BOLETA -->
                    <HBox spacing="15" alignment="CENTER">
                        <Label text="Precio Boleta:"/>
                        <TextField fx:id="fid_precioBoleta" prefWidth="200"/>
                        <Button text="Definir" onAction="#On_definirPrecio"/>
                    </HBox>

                    <!-- ACCIONES -->
                    <HBox spacing="20" alignment="CENTER">
                        <Button text="Aprobar Presupuesto" onAction="#On_aprobarPresupuesto"/>
                        <Button text="Calcular Balance" onAction="#On_calcularEquilibrio"/>
                    </HBox>

                    <!-- RESULTADO -->
                    <Label fx:id="lbl_resultado"
                           text="Resultado..."
                           style="-fx-font-size: 18px; -fx-text-fill: blue;"/>

                </VBox>
            </center>

            <!-- =========================
                 BOTTOM: BOTÓN VOLVER
            ========================= -->
            <bottom>
                <HBox alignment="CENTER">
                    <Button text="Volver" onAction="#On_volver">
                        <HBox.margin>
                            <Insets top="20" bottom="20"/>
                        </HBox.margin>
                    </Button>
                </HBox>
            </bottom>

        </BorderPane>

    </children>

</AnchorPane>