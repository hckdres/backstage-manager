<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <AnchorPane layoutX="40.0" layoutY="30.0" prefHeight="740.0" prefWidth="1120.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0, 0, 4);">

            <children>

                <!-- CABECERA -->
                <HBox layoutX="30.0" layoutY="25.0" prefHeight="80.0" prefWidth="1060.0" spacing="20.0">
                    <children>

                        <VBox prefHeight="80.0" prefWidth="780.0" spacing="6.0">
                            <children>
                                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Centro de Actividad" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" text="Consulta movimientos, alertas, mensajes y solicitudes del sistema" />
                            </children>
                        </VBox>

                        <VBox prefHeight="80.0" prefWidth="260.0" spacing="8.0">
                            <children>
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Actividad pendiente" />
                                <Label fx:id="fid_lbl_total_actividad" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f97316;" text="8 nuevos" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <Separator layoutX="30.0" layoutY="120.0" prefWidth="1060.0" />

                <!-- FILTROS TIPO PESTAÑAS -->
                <HBox layoutX="30.0" layoutY="145.0" prefHeight="55.0" prefWidth="1060.0" spacing="12.0">
                    <children>
                        <Button fx:id="fid_bt_filtro_todo" mnemonicParsing="false" onAction="#On_filtro_todo" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;" text="Todo" />

                        <Button fx:id="fid_bt_filtro_accesos" mnemonicParsing="false" onAction="#On_filtro_accesos" prefHeight="40.0" prefWidth="135.0" style="-fx-background-color: #eff6ff; -fx-text-fill: #1d4ed8; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-color: #bfdbfe; -fx-border-radius: 20;" text="Accesos" />

                        <Button fx:id="fid_bt_filtro_alertas" mnemonicParsing="false" onAction="#On_filtro_alertas" prefHeight="40.0" prefWidth="135.0" style="-fx-background-color: #fff7ed; -fx-text-fill: #c2410c; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-color: #fed7aa; -fx-border-radius: 20;" text="Alertas" />

                        <Button fx:id="fid_bt_filtro_mensajes" mnemonicParsing="false" onAction="#On_filtro_mensajes" prefHeight="40.0" prefWidth="135.0" style="-fx-background-color: #f5f3ff; -fx-text-fill: #6d28d9; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-color: #ddd6fe; -fx-border-radius: 20;" text="Mensajes" />

                        <Button fx:id="fid_bt_filtro_solicitudes" mnemonicParsing="false" onAction="#On_filtro_solicitudes" prefHeight="40.0" prefWidth="145.0" style="-fx-background-color: #ecfdf5; -fx-text-fill: #047857; -fx-font-weight: bold; -fx-background-radius: 20; -fx-border-color: #a7f3d0; -fx-border-radius: 20;" text="Solicitudes" />
                    </children>
                </HBox>

                <!-- PANEL IZQUIERDO -->
                <AnchorPane layoutX="30.0" layoutY="220.0" prefHeight="420.0" prefWidth="520.0" style="-fx-background-color: #f9fafb; -fx-background-radius: 18; -fx-border-color: #e5e7eb; -fx-border-radius: 18; -fx-border-width: 1;">

                    <children>

                        <Label layoutX="24.0" layoutY="20.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Actividad reciente" />
                        <Label layoutX="24.0" layoutY="48.0" style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" text="Últimos movimientos registrados en el sistema" />

                        <VBox layoutX="20.0" layoutY="85.0" prefHeight="310.0" prefWidth="480.0" spacing="12.0">
                            <children>

                                <Button fx:id="fid_bt_actividad_1" mnemonicParsing="false" onAction="#On_actividad_1" prefHeight="54.0" prefWidth="480.0" style="-fx-background-color: #ffffff; -fx-text-fill: #047857; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-border-color: #bbf7d0; -fx-border-radius: 14; -fx-border-width: 1.2;" text="● Entrada registrada - admin - Hoy 08:15 AM" />

                                <Button fx:id="fid_bt_actividad_2" mnemonicParsing="false" onAction="#On_actividad_2" prefHeight="54.0" prefWidth="480.0" style="-fx-background-color: #ffffff; -fx-text-fill: #c2410c; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-border-color: #fed7aa; -fx-border-radius: 14; -fx-border-width: 1.2;" text="● Alerta del sistema - intento fallido - Hoy 09:02 AM" />

                                <Button fx:id="fid_bt_actividad_3" mnemonicParsing="false" onAction="#On_actividad_3" prefHeight="54.0" prefWidth="480.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1d4ed8; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-border-color: #bfdbfe; -fx-border-radius: 14; -fx-border-width: 1.2;" text="● Mensaje recibido - soporte interno - Hoy 10:20 AM" />

                                <Button fx:id="fid_bt_actividad_4" mnemonicParsing="false" onAction="#On_actividad_4" prefHeight="54.0" prefWidth="480.0" style="-fx-background-color: #ffffff; -fx-text-fill: #6d28d9; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-border-color: #ddd6fe; -fx-border-radius: 14; -fx-border-width: 1.2;" text="● Solicitud pendiente - revisión de concierto - Hoy 11:45 AM" />

                                <Button fx:id="fid_bt_actividad_5" mnemonicParsing="false" onAction="#On_actividad_5" prefHeight="54.0" prefWidth="480.0" style="-fx-background-color: #ffffff; -fx-text-fill: #b91c1c; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-border-color: #fecaca; -fx-border-radius: 14; -fx-border-width: 1.2;" text="● Salida registrada - vendedor01 - Hoy 12:30 PM" />

                            </children>
                        </VBox>

                    </children>
                </AnchorPane>

                <!-- PANEL DERECHO MEJORADO -->
                <AnchorPane layoutX="580.0" layoutY="220.0" prefHeight="459.0" prefWidth="520.0" style="-fx-background-color: #ffffff; -fx-background-radius: 22; -fx-border-color: #e5e7eb; -fx-border-radius: 22; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.08), 16, 0, 0, 4);">

                    <children>

                        <!-- ENCABEZADO DEL DETALLE -->
                        <VBox layoutX="28.0" layoutY="24.0" prefHeight="55.0" prefWidth="454.0" spacing="5.0">
                            <children>
                                <Label style="-fx-font-size: 21px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Detalle de actividad" />
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" text="Información completa del movimiento seleccionado" />
                            </children>
                        </VBox>

                        <!-- TARJETA RESUMEN -->
                        <AnchorPane layoutX="28.0" layoutY="92.0" prefHeight="96.0" prefWidth="454.0" style="-fx-background-color: linear-gradient(to right, #eff6ff, #f8fafc); -fx-background-radius: 18; -fx-border-color: #dbeafe; -fx-border-radius: 18; -fx-border-width: 1;">

                            <children>

                                <VBox layoutX="22.0" layoutY="16.0" prefHeight="64.0" prefWidth="210.0" spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;" text="TIPO DE ACTIVIDAD" />
                                        <Label fx:id="fid_lbl_tipo_actividad" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2563eb;" text="Entrada registrada" />
                                    </children>
                                </VBox>

                                <VBox layoutX="265.0" layoutY="16.0" prefHeight="64.0" prefWidth="160.0" spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;" text="ESTADO" />
                                        <Label fx:id="fid_lbl_estado_actividad" style="-fx-background-color: #dcfce7; -fx-text-fill: #15803d; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 14 6 14;" text="Nuevo" />
                                    </children>
                                </VBox>

                            </children>
                        </AnchorPane>

                        <!-- DATOS PRINCIPALES -->
                        <AnchorPane layoutX="28.0" layoutY="205.0" prefHeight="92.0" prefWidth="454.0" style="-fx-background-color: #f9fafb; -fx-background-radius: 18; -fx-border-color: #e5e7eb; -fx-border-radius: 18; -fx-border-width: 1;">

                            <children>

                                <VBox layoutX="20.0" layoutY="15.0" prefHeight="62.0" prefWidth="190.0" spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" text="USUARIO" />
                                        <Label fx:id="fid_lbl_usuario_actividad" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="admin" />
                                    </children>
                                </VBox>

                                <VBox layoutX="245.0" layoutY="15.0" prefHeight="62.0" prefWidth="190.0" spacing="8.0">
                                    <children>
                                        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" text="FECHA Y HORA" />
                                        <Label fx:id="fid_lbl_fecha_actividad" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Hoy 08:15 AM" />
                                    </children>
                                </VBox>

                            </children>
                        </AnchorPane>

                        <!-- CHIPS DE INFORMACIÓN -->
                        <HBox layoutX="28.0" layoutY="314.0" prefHeight="38.0" prefWidth="454.0" spacing="10.0">
                            <children>
                                <Label fx:id="fid_lbl_modulo_actividad" prefHeight="34.0" prefWidth="220.0" style="-fx-background-color: #eef2ff; -fx-text-fill: #4338ca; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-padding: 8 12 8 12;" text="Módulo: Inicio de sesión" />

                                <Label fx:id="fid_lbl_origen_actividad" prefHeight="34.0" prefWidth="220.0" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-padding: 8 12 8 12;" text="Origen: Sistema" />
                            </children>
                        </HBox>

                        <!-- DESCRIPCIÓN -->
                        <VBox layoutX="28.0" layoutY="362.0" prefHeight="50.0" prefWidth="454.0" spacing="6.0">
                            <children>
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" text="DESCRIPCIÓN" />

                                <TextArea fx:id="fid_txt_detalle_actividad" prefHeight="9.0" prefWidth="468.0" promptText="Detalle completo de la actividad seleccionada..." style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-padding: 8; -fx-text-fill: #374151;" />
                            </children>
                        </VBox>

                    </children>
                </AnchorPane>

                <!-- BOTONES INFERIORES CUADRADOS Y SEPARADOS -->
                <HBox layoutX="610.0" layoutY="692.0" prefHeight="40.0" prefWidth="480.0" spacing="15.0">
                    <children>

                        <Button fx:id="fid_bt_marcar_revisado" mnemonicParsing="false" onAction="#On_marcar_revisado" prefHeight="46.0" prefWidth="170.0" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(22,163,74,0.22), 10, 0, 0, 2);" text="Marcar revisado" />

                        <Button fx:id="fid_bt_volver_actividad" mnemonicParsing="false" onAction="#On_volver_actividad" prefHeight="46.0" prefWidth="170.0" style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-border-color: #d1d5db; -fx-border-radius: 12; -fx-border-width: 1;" text="Volver" />

                    </children>
                </HBox>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>
