<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      prefHeight="500"
      prefWidth="400"
      style="-fx-background-color: #1e1e1e;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Detalle Nómina"
           style="-fx-font-size: 24px; -fx-text-fill: white; -fx-font-weight: bold;" />

    <Label fx:id="lblNombre"
           text="Nombre"
           style="-fx-text-fill: white; -fx-font-size: 18px;" />

    <Label fx:id="lblRol"
           text="Rol"
           style="-fx-text-fill: white; -fx-font-size: 18px;" />

    <Label fx:id="lblHoras"
           text="Horas"
           style="-fx-text-fill: white; -fx-font-size: 18px;" />

    <Label fx:id="lblExtra"
           text="Horas Extra"
           style="-fx-text-fill: white; -fx-font-size: 18px;" />

    <Label fx:id="lblTarifa"
           text="Tarifa"
           style="-fx-text-fill: white; -fx-font-size: 18px;" />

    <Label fx:id="lblTotal"
           text="Total"
           style="-fx-text-fill: white; -fx-font-size: 18px;" />

    <Label fx:id="lblEstado"
           text="Estado"
           style="-fx-text-fill: white; -fx-font-size: 18px;" />

    <Button text="Volver"
            onAction="#On_volver"
            style="-fx-font-size: 16px;" />

</VBox>
