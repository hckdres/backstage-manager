<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0"
            prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <VBox alignment="CENTER"
              spacing="35.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <padding>
                <Insets top="60.0"
                         right="80.0"
                         bottom="60.0"
                         left="80.0"/>
            </padding>

            <Label text="Seleccionar Concierto"
                   style="
                        -fx-font-size: 34px;
                        -fx-font-weight: bold;
                   "/>

            <Label text="Seleccione el concierto para administrar sus finanzas"
                   style="
                        -fx-font-size: 18px;
                   "/>

            <ComboBox fx:id="comboConciertos"
                      prefWidth="500.0"
                      prefHeight="50.0"
                      style="
                            -fx-font-size: 16px;
                      "/>

            <Button text="Continuar"
                    onAction="#On_continuar"
                    prefWidth="260.0"
                    prefHeight="50.0"
                    style="
                        -fx-font-size: 16px;
                        -fx-font-weight: bold;
                    "/>

            <Button text="Volver"
                    onAction="#On_volver"
                    prefWidth="260.0"
                    prefHeight="50.0"
                    style="
                        -fx-font-size: 16px;
                    "/>

        </VBox>

    </children>

</AnchorPane>