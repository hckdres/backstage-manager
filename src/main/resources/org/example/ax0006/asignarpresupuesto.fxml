<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <VBox spacing="15.0"
              AnchorPane.topAnchor="20.0"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.bottomAnchor="20.0">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- TITULO -->
            <Label text="Asignar Presupuesto a Concierto"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;" />

            <!-- TABLA -->
            <TableView fx:id="tablaFinanzas"
                       prefHeight="350.0">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"
                                 prefWidth="100.0"/>

                    <TableColumn fx:id="colPresupuesto"
                                 text="Presupuesto"
                                 prefWidth="300.0"/>

                    <TableColumn fx:id="colAprobado"
                                 text="Aprobado"
                                 prefWidth="150.0"/>

                </columns>

            </TableView>

            <!-- COMBO -->
            <Label text="Seleccione el concierto:"/>

            <ComboBox fx:id="comboConciertos"
                      prefWidth="400.0"/>

            <!-- BOTONES -->
            <VBox spacing="10">

                <Button text="Asignar Presupuesto"
                        onAction="#On_asignarPresupuesto"
                        prefWidth="250.0"
                        prefHeight="40.0"/>

                <Button text="Volver"
                        onAction="#On_volver"
                        prefWidth="150.0"
                        prefHeight="35.0"/>

            </VBox>

        </VBox>

    </children>

</AnchorPane>