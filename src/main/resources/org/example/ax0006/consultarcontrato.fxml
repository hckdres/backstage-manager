<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <VBox spacing="20.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              style="-fx-background-color: #f4f6f8; -fx-padding: 40;">

            <VBox spacing="20.0"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);">

                <Label text="Consultar Contrato"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

                <Separator />

                <!-- Búsqueda -->
                <VBox spacing="10.0">
                    <Label text="Búsqueda"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                    <Label text="ID del contrato"
                           style="-fx-font-weight: bold;" />

                    <HBox spacing="10.0">
                        <TextField fx:id="txtIdContrato"
                                   promptText="Ingrese el ID del contrato"
                                   style="-fx-background-radius: 8;" />

                        <Button text="Buscar"
                                onAction="#buscarContrato"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8;" />
                    </HBox>
                </VBox>

                <Separator />

                <!-- Info -->
                <VBox spacing="10.0">
                    <Label text="Información del Contrato"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                    <Label text="Fecha"
                           style="-fx-font-weight: bold;" />

                    <Label fx:id="lblFecha"
                           text="--/--/----"
                           style="-fx-text-fill: #555;" />
                </VBox>

                <Separator />

                <!-- Cláusulas -->
                <VBox spacing="10.0">
                    <Label text="Cláusulas"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                    <ListView fx:id="listClausulas"
                              prefHeight="200.0" />
                </VBox>

                <Separator />

                <!-- Botón volver -->
                <HBox alignment="CENTER_RIGHT">
                    <Button text="Volver"
                            onAction="#volver"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 8;" />
                </HBox>

            </VBox>
        </VBox>
    </children>
</AnchorPane>