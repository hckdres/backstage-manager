<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox prefHeight="70.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Liquidación de Horas" />
        </HBox>
    </top>
    <center>
        <VBox spacing="20.0" style="-fx-padding: 30;">
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Liquidación por Evento" />
            <Separator />
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label style="-fx-font-weight: bold;" text="Seleccione evento:" />
                <ComboBox fx:id="comboEvento" prefWidth="300.0" />
            </HBox>
            <TableView fx:id="tablaNominas" prefHeight="500.0">
                <columns>
                    <TableColumn fx:id="colTrabajador" prefWidth="200.0" text="Trabajador" />
                    <TableColumn fx:id="colHoras" prefWidth="150.0" text="Horas trabajadas" />
                    <TableColumn fx:id="colTarifa" prefWidth="150.0" text="Tarifa por hora" />
                    <TableColumn fx:id="colExtra" prefWidth="150.0" text="Horas extra" />
                    <TableColumn fx:id="colTotal" prefWidth="150.0" text="Total" />
                    <TableColumn fx:id="colEstado" prefWidth="150.0" text="Estado" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
                <Label style="-fx-font-weight: bold;" text="Total general:" />
                <Label fx:id="lblTotalGeneral" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" text="$0" />
                <Button fx:id="btnGenerarReporte" text="Generar Reporte" />
            </HBox>
        </VBox>
    </center>
</BorderPane>