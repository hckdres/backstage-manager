<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
    <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Liquidación de Horas" />

        <HBox spacing="10">
            <Label style="-fx-font-weight: bold;" text="Evento:" />
            <ComboBox fx:id="comboEvento" prefWidth="300.0" promptText="Seleccione un evento" />
        </HBox>

        <TableView fx:id="tablaNominas" prefHeight="400.0">
            <columns>
                <TableColumn fx:id="colTrabajador" prefWidth="150.0" text="Trabajador" />
                <TableColumn fx:id="colHoras" prefWidth="100.0" text="Horas" />
                <TableColumn fx:id="colTarifa" prefWidth="100.0" text="Tarifa" />
                <TableColumn fx:id="colExtra" prefWidth="100.0" text="Extra" />
                <TableColumn fx:id="colTotal" prefWidth="100.0" text="Total" />
                <TableColumn fx:id="colEstado" prefWidth="100.0" text="Estado" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Label style="-fx-font-weight: bold;" text="Total general:" />
            <Label fx:id="lblTotalGeneral" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" text="$0" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="btnGenerarReporte" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5;" text="Generar Reporte" />
        </HBox>
    </VBox>
</AnchorPane>