<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<Pane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Text layoutX="350.0" layoutY="60.0" text="Gestión de Mantenimiento Técnico">
            <font><Font name="System Bold" size="28.0"/></font>
        </Text>

        <StackPane layoutX="50.0" layoutY="100.0" prefHeight="650.0" prefWidth="1100.0">
            <children>

                <VBox fx:id="panel_lista" spacing="20.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #374151;" text="Equipos Actualmente en Mantenimiento" />

                        <ScrollPane fitToWidth="true" prefHeight="450.0" style="-fx-background-color: transparent; -fx-background: white;">
                            <content>
                                <VBox fx:id="vb_lista_mantenimientos" spacing="10.0" style="-fx-padding: 5;">
                                </VBox>
                            </content>
                        </ScrollPane>

                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <Button onAction="#on_bt_volver" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Volver al Menú Principal" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#on_bt_abrir_creacion" prefHeight="45.0" prefWidth="300.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" text="Registrar Nuevo Mantenimiento" />
                            </children>
                        </HBox>
                    </children>
                </VBox>


                <HBox fx:id="panel_creacion" spacing="40.0" managed="false" visible="false">
                    <children>

                        <VBox prefWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Definir Horario" />
                                <VBox spacing="5.0">
                                    <Label text="Tipo de Registro:" />
                                    <TextField fx:id="tf_idConcierto" editable="false" prefHeight="35.0" style="-fx-background-color: #e5e7eb; -fx-text-fill: #6b7280;" />
                                </VBox>
                                <HBox spacing="10.0">
                                    <VBox spacing="5.0">
                                        <Label text="Fecha Inicio:" />
                                        <DatePicker fx:id="dp_fechaInicio" prefWidth="190.0" />
                                    </VBox>
                                    <VBox spacing="5.0">
                                        <Label text="Fecha Fin:" />
                                        <DatePicker fx:id="dp_fechaFin" prefWidth="190.0" />
                                    </VBox>
                                </HBox>
                                <HBox spacing="10.0">
                                    <VBox spacing="5.0">
                                        <Label text="Hora Inicio (HH:mm):" />
                                        <TextField fx:id="tf_horaInicio" prefHeight="35.0" />
                                    </VBox>
                                    <VBox spacing="5.0">
                                        <Label text="Hora Fin (HH:mm):" />
                                        <TextField fx:id="tf_horaFin" prefHeight="35.0" />
                                    </VBox>
                                </HBox>
                                <Separator style="-fx-padding: 10 0 10 0;" />
                                <Button onAction="#on_bt_crear" prefHeight="50.0" prefWidth="410.0" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="GUARDAR MANTENIMIENTO" />
                                <Button onAction="#on_bt_cancelar_creacion" prefHeight="35.0" prefWidth="410.0" style="-fx-background-color: #ef4444; -fx-text-fill: white;" text="Cancelar" />
                            </children>
                        </VBox>

                        <VBox prefWidth="610.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Seleccionar Equipos" />
                                <HBox spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="cb_objetos" prefHeight="40.0" prefWidth="450.0" promptText="Buscar objeto..." />
                                        <Button onAction="#on_bt_agregar_lista" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;" text="Añadir" />
                                    </children>
                                </HBox>
                                <Label text="Equipos listos para mantenimiento:" />
                                <ListView fx:id="lv_objetos_seleccionados" prefHeight="400.0" prefWidth="550.0" />
                                <Button onAction="#on_bt_quitar_lista" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #f87171; -fx-text-fill: white;" text="Quitar Seleccionado" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </StackPane>
    </children>
</Pane>