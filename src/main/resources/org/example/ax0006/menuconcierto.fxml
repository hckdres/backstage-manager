<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox prefHeight="80.0" alignment="CENTER_LEFT" style="-fx-padding: 0 40; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <children>
                <Label text="Módulo de Conciertos" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
            </children>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="25" maxWidth="400.0">
            <children>
                <Button onAction="#On_CrearConcierto" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;" text="Crear Solicitud de Concierto" />
                <Button onAction="#On_ConsultarConciertos" prefHeight="50.0" prefWidth="350.0" text="Consultar Solicitudes" />
                <Button onAction="#On_ConsultarCProgramado" prefHeight="50.0" prefWidth="350.0" text="Conciertos Programados" />
                <Separator prefWidth="350.0" />
                <Button onAction="#on_bt_crearInventario" prefHeight="60.0" prefWidth="350.0" style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-weight: bold;" text="CREAR INVENTARIO PARA CONCIERTO" />
                <Button onAction="#On_btvolver" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #ef4444; -fx-text-fill: white;" text="Volver al Menú Principal" />
            </children>
        </VBox>
    </center>
</BorderPane>