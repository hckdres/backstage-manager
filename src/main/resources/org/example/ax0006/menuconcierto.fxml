<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom, #eef2f7, #e4ebf3);"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- BARRA SUPERIOR -->
    <top>
        <HBox prefHeight="80.0" alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: white;
                     -fx-padding: 20 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3);">

            <children>
                <Label text="Gestión de Conciertos"
                       style="-fx-font-size: 26px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #08233f;
                              -fx-font-family: 'Segoe UI', 'Arial';"/>
            </children>

        </HBox>
    </top>

    <!-- CONTENIDO CENTRAL -->
    <center>
        <AnchorPane prefHeight="730.0" prefWidth="1200.0">

            <children>

                <VBox alignment="CENTER"
                      layoutX="450.0"
                      layoutY="150.0"
                      spacing="25"
                      style="-fx-background-color: white;
                             -fx-padding: 40;
                             -fx-background-radius: 15;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 5);">

                    <children>

                        <!-- CREAR -->
                        <Button fx:id="fid_bt_CrearConcierto"
                                onAction="#On_CrearConcierto"
                                prefWidth="320"
                                prefHeight="45"
                                text="Crear Solicitud de Concierto"
                                style="-fx-background-color: linear-gradient(to right, #32649d, #357ABD);
                                       -fx-text-fill: white;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;" />

                        <!-- CONSULTAR SOLICITUDES -->
                        <Button fx:id="fid_bt_ConsultarSolicitudes"
                                onAction="#On_ConsultarConciertos"
                                prefWidth="320"
                                prefHeight="45"
                                text="Consultar Solicitudes"
                                style="-fx-background-color: linear-gradient(to right, #b3bcb7, #27ae60);
                                       -fx-text-fill: white;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;" />

                        <!-- CONSULTAR PROGRAMADOS -->
                        <Button fx:id="fid_bt_ConsultarProgramados"
                                onAction="#On_ConsultarCProgramado"
                                prefWidth="320"
                                prefHeight="45"
                                text="Conciertos Programados"
                                style="-fx-background-color: linear-gradient(to right, #85cfee, #7d3c98);
                                       -fx-text-fill: white;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;" />

                        <!-- VOLVER -->
                        <Button fx:id="fid_bt_volver"
                                onAction="#On_btvolver"
                                prefWidth="320"
                                prefHeight="45"
                                text="Volver al menú"
                                style="-fx-background-color: linear-gradient(to right, #7070fa, #c0392b);
                                       -fx-text-fill: white;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;" />

                    </children>

                </VBox>

            </children>
        </AnchorPane>
    </center>

</BorderPane>