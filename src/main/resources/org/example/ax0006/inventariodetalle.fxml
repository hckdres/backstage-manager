<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800" prefWidth="1200" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <HBox spacing="600" style="-fx-background-color: white; -fx-padding: 15;">
            <children>
                <Label fx:id="fid_InventarioNombre" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Inventario" />
                <Button onAction="#On_volver" text="Volver" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <children>

                <TableView fx:id="tablaObjetos" fixedCellSize="30" style="-fx-font-size: 16px;">
                    <columns>
                  <TableColumn fx:id="colID" text="ID" />
                  <TableColumn fx:id="colTipoObjeto" text="Tipo de Objeto" />
                        <TableColumn fx:id="colModelo" text="Modelo" />
                        <TableColumn fx:id="colEstado" text="Estado" />
                  <TableColumn fx:id="colObservacion" text="Observacion" />
                        <TableColumn fx:id="colDisponible" text="Disponible" />
                    </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
                </TableView>

                <HBox spacing="10">
                    <children>
                        <Button onAction="#On_agregarObjeto" text="Agregar Objeto" />
                        <Button onAction="#On_eliminarObjeto" text="Eliminar Objeto" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>
