<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f4f6f8;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <children>
                <Label text="Gestión de Conciertos Programados" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="fid_bt_volver" text="Volver al Menú" onAction="#On_volver" prefWidth="150" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <TableView fx:id="tablaConciertos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNombreConcierto" text="Nombre" prefWidth="250.0"/>
                    <TableColumn fx:id="colFechaInicio" text="Fecha Inicio" prefWidth="120.0"/>
                    <TableColumn fx:id="colHoraInicio" text="Hora Inicio" prefWidth="100.0"/>
                    <TableColumn fx:id="colAforo" text="Aforo" prefWidth="100.0"/>
                    <TableColumn fx:id="colContrato" text="Contrato" prefWidth="120.0"/>
                    <TableColumn fx:id="colDetalles" text="Información" prefWidth="150.0"/> <TableColumn fx:id="colAccion" text="Gestionar" prefWidth="150.0"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>