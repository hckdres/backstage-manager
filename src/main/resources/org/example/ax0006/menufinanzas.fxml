<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0"
            prefWidth="1200.0"
            xmlns:fx="http://javafx.com/fxml">

    <children>

        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <!-- =========================
                 TITULO
            ========================= -->
            <top>

                <VBox alignment="CENTER"
                      spacing="10">

                    <padding>
                        <Insets top="40"
                                bottom="30"/>
                    </padding>

                    <Label text="Módulo de Finanzas"
                           style="-fx-font-size: 32px;
                                  -fx-font-weight: bold;"/>

                    <Label text="Gestión financiera de conciertos"
                           style="-fx-font-size: 16px;
                                  -fx-text-fill: #6b7280;"/>

                </VBox>

            </top>

            <!-- =========================
                 CONTENIDO
            ========================= -->
            <center>

                <VBox alignment="CENTER"
                      spacing="30">

                    <padding>
                        <Insets top="50"
                                left="50"
                                right="50"
                                bottom="50"/>
                    </padding>

                    <!-- CREAR -->
                    <Button fx:id="fid_bt_CrearFinanzasConcierto"
                            text="Crear Finanzas de un Concierto"
                            onAction="#On_CrearFinanzasConcierto"
                            prefWidth="420"
                            prefHeight="70"
                            style="-fx-background-color: #2563eb;
                                   -fx-text-fill: white;
                                   -fx-font-size: 18px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 12;"/>

                    <!-- CONSULTAR -->
                    <Button fx:id="fid_bt_ConsultarFinanzasConciertos"
                            text="Consultar Finanzas de Conciertos"
                            onAction="#On_ConsultarFinanzasConcierto"
                            prefWidth="420"
                            prefHeight="70"
                            style="-fx-background-color: #16a34a;
                                   -fx-text-fill: white;
                                   -fx-font-size: 18px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 12;"/>

                </VBox>

            </center>

            <!-- =========================
                 VOLVER
            ========================= -->
            <bottom>

                <HBox alignment="CENTER">

                    <padding>
                        <Insets top="20"
                                bottom="40"/>
                    </padding>

                    <Button fx:id="fid_bt_volver"
                            text="Volver"
                            onAction="#On_btvolver"
                            prefWidth="180"
                            prefHeight="50"
                            style="-fx-background-color: #374151;
                                   -fx-text-fill: white;
                                   -fx-font-size: 15px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 10;"/>

                </HBox>

            </bottom>

        </BorderPane>

    </children>

</AnchorPane>