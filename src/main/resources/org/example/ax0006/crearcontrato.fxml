<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.ListView?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <VBox spacing="20.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              style="-fx-background-color: #f4f6f8; -fx-padding: 40;">

            <VBox spacing="20.0"
                  style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);">

                <Label text="Crear Contrato"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

                <Separator />

                <!-- Datos -->
                <VBox spacing="10.0">
                    <Label text="Datos del Contrato"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                    <Label text="Fecha del contrato"
                           style="-fx-font-weight: bold;" />

                    <DatePicker fx:id="dateFecha"
                                style="-fx-background-radius: 8;" />
                </VBox>

                <Separator />

                <!-- Cláusulas -->
                <VBox spacing="10.0">
                    <Label text="Cláusulas"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                    <Label text="Nueva cláusula"
                           style="-fx-font-weight: bold;" />

                    <TextArea fx:id="txtClausula"
                              prefHeight="80.0"
                              wrapText="true"
                              style="-fx-background-radius: 8;" />

                    <Button text="Agregar cláusula"
                            onAction="#agregarClausula"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8;" />

                    <Label text="Cláusulas agregadas"
                           style="-fx-font-weight: bold;" />

                    <ListView fx:id="listClausulas"
                              prefHeight="150.0" />
                </VBox>

                <Separator />

                <!-- Botones -->
                <HBox spacing="15.0">
                    <Button text="Guardar contrato"
                            onAction="#guardarContrato"
                            style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 8;" />

                    <Button text="Cancelar"
                            onAction="#cancelar"
                            style="-fx-background-color: #bdc3c7; -fx-text-fill: black; -fx-background-radius: 8;" />
                </HBox>

            </VBox>
        </VBox>
    </children>
</AnchorPane>