<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<Pane maxHeight="-Infinity" maxWidth="-Infinity"
      minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="800.0" prefWidth="1200.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Text layoutX="22.0" layoutY="46.0" strokeType="OUTSIDE" strokeWidth="0.0" text="MENU:">
         <font>
            <Font name="System Italic" size="30.0" />
         </font>
      </Text>
      <Button fx:id="fid_bt_volver" layoutX="1101.0" layoutY="734.0" mnemonicParsing="false" onAction="#On_btvolver" text="Volver" />
      <Text fx:id="fid_Bienvenido" layoutX="22.0" layoutY="77.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Bienvenido ">
         <font>
            <Font size="19.0" />
         </font>
      </Text>
      <!-- CREAR INVENTARIO -->
      <Button fx:id="bt_crearInventario"
              layoutX="450.0"
              layoutY="200.0"
              prefWidth="300.0"
              text="Crear Inventario"
              onAction="#on_bt_crearInventario"/>

      <!-- CREAR TIPO OBJETO -->
      <Button fx:id="bt_crearTipoObjeto"
              layoutX="450.0"
              layoutY="270.0"
              prefWidth="300.0"
              text="Crear Tipo de Objeto"
              onAction="#on_bt_crearTipoObjeto"/>

      <!-- CREAR HORARIO -->
      <Button fx:id="bt_crearHorario"
              layoutX="450.0"
              layoutY="340.0"
              prefWidth="300.0"
              text="Crear Horario"
              onAction="#on_bt_crearHorario"/>

      <!-- ASIGNAR OBJETO -->
      <Button fx:id="bt_asignarObjeto"
              layoutX="450.0"
              layoutY="410.0"
              prefWidth="300.0"
              text="Asignar Objeto a Inventario"
              onAction="#on_bt_asignarObjeto"/>

      <!-- RESERVAR INVENTARIO -->
      <Button fx:id="bt_reservar"
              layoutX="450.0"
              layoutY="480.0"
              prefWidth="300.0"
              text="Reservar Inventario (Horario)"
              onAction="#on_bt_reservar"/>

      <!-- CONSULTAR INVENTARIO -->
      <Button fx:id="bt_consultarInventario"
              layoutX="450.0"
              layoutY="550.0"
              prefWidth="300.0"
              text="Consultar Inventario"
              onAction="#on_bt_consultarInventario"/>
   </children>
</Pane>

