<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <!-- CARD PRINCIPAL -->
        <AnchorPane layoutX="40.0" layoutY="30.0" prefHeight="740.0" prefWidth="1120.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0, 0, 4);">

            <children>

                <!-- CABECERA -->
                <HBox layoutX="30.0" layoutY="25.0" prefHeight="70.0" prefWidth="1060.0" spacing="20.0">
                    <children>

                        <VBox prefHeight="70.0" prefWidth="760.0" spacing="6.0">
                            <children>
                                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Gestor de Conciertos" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" text="Panel principal del sistema" />
                            </children>
                        </VBox>

                        <VBox prefHeight="70.0" prefWidth="280.0" spacing="8.0">
                            <children>
                                <Label fx:id="fid_Bienvenido" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;" text="Bienvenido, Usuario" />
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="fid_bt_perfil" mnemonicParsing="false" onAction="#On_Perfil" prefHeight="36.0" prefWidth="120.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="Perfil" />
                                        <Button fx:id="fid_bt_volver" mnemonicParsing="false" onAction="#On_btvolver" prefHeight="36.0" prefWidth="150.0" style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-background-radius: 10;" text="Cerrar sesión" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <Separator layoutX="30.0" layoutY="110.0" prefWidth="1060.0" />

                <!-- ZONA CENTRAL DE ACCESOS -->
                <HBox layoutX="85.0" layoutY="170.0" prefHeight="450.0" prefWidth="950.0" spacing="50.0">
                    <children>

                        <!-- COLUMNA 1 -->
                        <VBox prefHeight="450.0" prefWidth="280.0" spacing="22.0">
                            <children>
                                <Button fx:id="fid_Menu_Conciertos" mnemonicParsing="false" onAction="#On_Menu_Conciertos" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #d5b1fd; -fx-text-fill: #411c91; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="Gestión de&#10;Conciertos" />
                                <Button fx:id="fid_AnalisisFinanciero" mnemonicParsing="false" onAction="#On_irAnalisisFinanciero" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #e37070; -fx-text-fill: #000000; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="Analisis&#10;Financiero" />
                                <Button fx:id="fid_bt_recintos" mnemonicParsing="false" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1f2937; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="N" />
                            </children>
                        </VBox>

                        <!-- COLUMNA 2 -->
                        <VBox prefHeight="450.0" prefWidth="280.0" spacing="22.0">
                            <children>
                                <Button fx:id="fid_bt_entradas" mnemonicParsing="false" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1f2937; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="N" />
                                <Button fx:id="fid_bt_clientes" mnemonicParsing="false" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1f2937; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="N" />
                                <Button fx:id="fid_bt_reportes" mnemonicParsing="false" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #91c3ff; -fx-text-fill: #0b418d; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="Reportes" />
                            </children>
                        </VBox>

                        <!-- COLUMNA 3 -->
                        <VBox prefHeight="450.0" prefWidth="280.0" spacing="22.0">
                            <children>
                                <Button fx:id="fid_bt_calendario" mnemonicParsing="false" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1f2937; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="N" />
                                <Button fx:id="fid_bt_configuracion" mnemonicParsing="false" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1f2937; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #dbe2ea; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="N" />
                                <Button fx:id="fid_bt_admin" mnemonicParsing="false" onAction="#On_admin" prefHeight="120.0" prefWidth="280.0" style="-fx-background-color: #ecfdf5; -fx-text-fill: #047857; -fx-font-size: 17px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-border-color: #a7f3d0; -fx-border-radius: 18; -fx-border-width: 1.2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 10, 0, 0, 2);" text="Administrar&#10;Usuarios" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- PIE -->
                <Label layoutX="30.0" layoutY="690.0" style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;" text="Accede rápidamente a los módulos principales del sistema" />

            </children>
        </AnchorPane>

    </children>
</AnchorPane>
